  {
    "input_schema": {
      "properties": {
        "file_path": {
          "description": "The absolute path to the file to modify",
          "type": "string"
        },
        "hash_line": {
          "description": "Hash of the line to replace (alternative to old_string; survives whitespace/indentation drift)",
          "type": "string"
        },
        "new_string": {
          "description": "The text to replace it with (must be different from old_string)",
          "type": "string"
        },
        "old_string": {
          "description": "The text to replace",
          "type": "string"
        },
        "replace_all": {
          "description": "Replace all occurrences of old_string (default false)",
          "type": "boolean"
        }
      },
      "required": [
        "file_path",
        "new_string"
      ],
      "type": "object"
    },
    "name": "Edit"
  },
